## VideoCaptionsAI — Environment Configuration
## Copy this file to `.env` and fill in your keys

# ---- AI Copilot (LangGraph + LLM) ----
# OpenAI-compatible API key (required for Copilot)
LLM_API_KEY=

# Model name (default: gpt-4o)
LLM_MODEL_NAME=gpt-4o

# OpenAI-compatible base URL (default: https://api.openai.com/v1)
# For Alibaba: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_OPENAI_BASE=https://api.openai.com/v1

# LLM temperature (default: 0)
LLM_TEMPERATURE=0

# ---- Search Tool ----
# Tavily API key for web search in Copilot (https://tavily.com)
TAVILY_API_KEY=

# ---- Optional: Monitoring ----
# LangSmith API key (https://smith.langchain.com)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=VideoCaptionsAI

# ---- Whisper (Speech Recognition) ----
# Model size: tiny / base / small / medium / large-v3
WHISPER_MODEL=large-v3

# ---- Server ----
# Override default port (optional: auto-selects free port)
# PORT=8000

# Auth secret (change in production)
# SECRET_KEY=your-secret-here
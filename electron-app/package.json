{
  "name": "videocaptionsai-desktop",
  "version": "1.0.0",
  "description": "VideoCaptionsAI - Desktop Application",
  "author": "VideoCaptionsAI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.videocaptionsai.app",
    "productName": "VideoCaptionsAI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoCaptionsAI",
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052"
    },
    "extraResources": [
      {
        "from": "../VideoSubs/dist/VideoCaptionsAI",
        "to": "backend"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
